---
config:
  theme: base
  themeVariables:
    primaryColor: "#dbeafe"
    primaryTextColor: "#0b2545"
    primaryBorderColor: "#1e40af"
    lineColor: "#1e40af"
    secondaryColor: "#f3f4f6"
    tertiaryColor: "#ffffff"
    clusterBkg: "#f8fafc"
    clusterBorder: "#94a3b8"
    fontFamily: "Inter, Arial, sans-serif"
    fontSize: "15px"
  flowchart:
    htmlLabels: true
    curve: basis
    nodeSpacing: 50
    rankSpacing: 70
---
flowchart LR
    %% =========================
    %% 1. Source
    %% =========================
    subgraph SRC["1 · DATA SOURCE"]
        direction TB
        BQ[("BigQuery<br/>Fact_Demand_Hourly<br/>+ Dim_Time + Dim_Weather")]
    end

    %% =========================
    %% 2. Preprocessing
    %% =========================
    subgraph PRE["2 · PREPROCESSING"]
        direction TB
        P1["Datetime Parsing<br/>pickup_time_key → hour, dow"]
        P2["Numerical Downcast<br/>float64 → 32, int64 → 32"]
        P3["MinMax / Standard Scaler"]
        P1 --> P2 --> P3
    end

    %% =========================
    %% 3. Feature Engineering
    %% =========================
    subgraph FE["3 · FEATURE ENGINEERING"]
        direction TB
        F1["Cyclical Time<br/>hour_sin, hour_cos<br/>dow_sin, dow_cos"]
        F2["Lag Features<br/>1h · 2h · 24h · 168h"]
        F3["Exogenous Weather<br/>Temperature · Precipitation"]
        F4["Spatial / Service<br/>pulocationid · service_type_key"]
    end

    %% =========================
    %% 4. Train / Test Split
    %% =========================
    subgraph SPLIT["4 · CHRONOLOGICAL SPLIT"]
        direction TB
        SP1["Train · historical window<br/>Jun – Oct"]
        SP2["Test · future hold-out<br/>Nov"]
    end

    %% =========================
    %% 5. Model Training
    %% =========================
    subgraph TRAIN["5 · MODEL TRAINING"]
        direction TB
        T1(("XGBoost"))
        T2(("Random<br/>Forest"))
        T3(("LSTM"))
    end

    %% =========================
    %% 6. Evaluation
    %% =========================
    subgraph EVAL["6 · EVALUATION"]
        direction TB
        E1["RMSE · MAE · R²"]
        E2["Segmented analysis<br/>borough &amp; rush-hour"]
    end

    %% =========================
    %% 7. Registry
    %% =========================
    subgraph REG["7 · MODEL REGISTRY"]
        direction TB
        R1["xgboost/*.joblib"]
        R2["random_forest/*.joblib"]
        R3["lstm/*.keras"]
        R4["scalers/*.pkl"]
    end

    %% =========================
    %% 8. Inference
    %% =========================
    subgraph INF["8 · INFERENCE"]
        direction TB
        I1["DemandPredictor<br/>(unified interface)"]
        I2["Streamlit ML Predictor<br/>real-time forecast"]
    end

    %% Flow
    BQ --> P1
    P3 --> F1
    P3 --> F2
    P3 --> F3
    P3 --> F4

    F1 --> SP1
    F2 --> SP1
    F3 --> SP1
    F4 --> SP1
    F1 --> SP2
    F2 --> SP2
    F3 --> SP2
    F4 --> SP2

    SP1 --> T1
    SP1 --> T2
    SP1 --> T3
    SP2 --> E1
    T1 --> E1
    T2 --> E1
    T3 --> E1
    E1 --> E2

    T1 --> R1
    T2 --> R2
    T3 --> R3
    P3 -.serialize.-> R4

    R1 --> I1
    R2 --> I1
    R3 --> I1
    R4 --> I1
    I1 --> I2

    %% Styling — pastel report-ready palette
    classDef src   fill:#dbeafe,stroke:#1e40af,color:#0b2545,stroke-width:2px
    classDef pre   fill:#e0f2fe,stroke:#0369a1,color:#0c4a6e,stroke-width:2px
    classDef fe    fill:#dcfce7,stroke:#16a34a,color:#14532d,stroke-width:2px
    classDef sp    fill:#fef9c3,stroke:#ca8a04,color:#713f12,stroke-width:2px
    classDef train fill:#f3e8ff,stroke:#7c3aed,color:#3b0764,stroke-width:2px
    classDef eval  fill:#ffe4e6,stroke:#be123c,color:#4c0519,stroke-width:2px
    classDef reg   fill:#ffedd5,stroke:#c2410c,color:#431407,stroke-width:2px
    classDef inf   fill:#cffafe,stroke:#0e7490,color:#083344,stroke-width:2px

    class BQ src
    class P1,P2,P3 pre
    class F1,F2,F3,F4 fe
    class SP1,SP2 sp
    class T1,T2,T3 train
    class E1,E2 eval
    class R1,R2,R3,R4 reg
    class I1,I2 inf
