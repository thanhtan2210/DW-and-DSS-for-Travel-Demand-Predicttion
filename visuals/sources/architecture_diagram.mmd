---
config:
  theme: base
  themeVariables:
    primaryColor: "#dbeafe"
    primaryTextColor: "#0b2545"
    primaryBorderColor: "#1e40af"
    lineColor: "#1e40af"
    secondaryColor: "#fef3c7"
    tertiaryColor: "#ecfdf5"
    fontFamily: "Inter, Arial, sans-serif"
    fontSize: "16px"
  flowchart:
    htmlLabels: true
    curve: basis
    nodeSpacing: 60
    rankSpacing: 80
---
flowchart LR
    %% =========================
    %% SOURCES
    %% =========================
    subgraph S["RAW DATA SOURCES"]
        direction TB
        S1["NYC TLC Trip Records<br/><i>Yellow / Green / FHV / FHVHV</i><br/>Parquet"]
        S2["NYC Weather History<br/><i>nyc_weather_2025.csv</i>"]
        S3["Taxi Zone Lookup<br/>+ Coordinates"]
    end

    %% =========================
    %% HYBRID PIPELINE
    %% =========================
    subgraph H["HYBRID ETL / ELT ENGINE"]
        direction TB
        subgraph L["LOCAL — Polars Streaming"]
            direction TB
            L1["scan_parquet<br/>(Lazy API)"]
            L2["Streaming Clean<br/>+ sink_parquet"]
            L3["Atomic Hourly<br/>Aggregation"]
            L1 --> L2 --> L3
        end
        subgraph C["CLOUD — BigQuery SQL ELT"]
            direction TB
            C1["Stage Raw Tables"]
            C2["SQL ELT —<br/>Standardize Gold Schema"]
            C3["Window Aggregations<br/>+ Dimensional Joins"]
            C1 --> C2 --> C3
        end
    end

    %% =========================
    %% DATA WAREHOUSE
    %% =========================
    subgraph DW["DATA WAREHOUSE — BigQuery Star Schema"]
        direction TB
        DW1[("Fact_Trips<br/><i>atomic grain</i>")]
        DW2[("Fact_Demand_Hourly<br/><i>aggregated grain<br/>= ML Feature Store</i>")]
        DW3{{"Conformed Dimensions<br/>Dim_Time · Dim_Location<br/>Dim_Service_Type · Dim_Weather"}}
    end

    %% =========================
    %% CONSUMERS
    %% =========================
    subgraph X["DOWNSTREAM CONSUMERS"]
        direction TB
        X1["ML Pipeline<br/>XGBoost · RF · LSTM"]
        X2["Streamlit DSS<br/>OLAP + AI Predictor"]
        X3["Power BI<br/>Executive Dashboard"]
    end

    %% =========================
    %% FLOWS
    %% =========================
    S1 -->|local FS| L1
    S2 --> L2
    S3 --> L2
    S1 -->|GCS upload| C1
    S2 --> C1
    S3 --> C1

    L3 -->|load| DW1
    L3 -->|load| DW2
    C3 -->|materialize| DW1
    C3 -->|materialize| DW2

    DW3 -.conformed.-> DW1
    DW3 -.conformed.-> DW2

    DW2 --> X1
    DW1 --> X2
    DW2 --> X2
    DW1 --> X3

    %% =========================
    %% STYLING
    %% =========================
    classDef src   fill:#dbeafe,stroke:#1e40af,color:#0b2545,stroke-width:2px
    classDef etl   fill:#e0f2fe,stroke:#0369a1,color:#0c4a6e,stroke-width:2px
    classDef dw    fill:#dcfce7,stroke:#16a34a,color:#14532d,stroke-width:2px
    classDef dim   fill:#fef9c3,stroke:#ca8a04,color:#713f12,stroke-width:2px
    classDef out   fill:#f3e8ff,stroke:#7c3aed,color:#3b0764,stroke-width:2px

    class S1,S2,S3 src
    class L1,L2,L3,C1,C2,C3 etl
    class DW1,DW2 dw
    class DW3 dim
    class X1,X2,X3 out
